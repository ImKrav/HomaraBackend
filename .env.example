# ============================================
# Homara Backend — Environment Variables
# ============================================
# All values below MIRROR the defaults inlined in `docker-compose.yml`.
#
# ┌─────────────────────────────────────────────────────────────┐
# │ You do NOT need to create a `.env` file to run the stack.  │
# │ `docker compose up -d --build` works out of the box:       │
# │   - PostgreSQL is provisioned with the credentials below   │
# │   - The backend container connects to it over the shared   │
# │     `homara-net` bridge network (host `db`, port 5432).    │
# └─────────────────────────────────────────────────────────────┘
#
# When is a `.env` file actually required?
#   • When you want to point the backend at a MANAGED / REMOTE
#     database (Supabase, Neon, AWS RDS, etc.) instead of the
#     local `db` service. Just override DATABASE_URL below.
#   • When you run the backend OUTSIDE Docker with `npm run dev`.
#   • When you want to override any of the inlined defaults below.

# ───────────────────────────────────────────────────────────────
# Database Connection URL
# ───────────────────────────────────────────────────────────────
# Pick ONE of the two options below. The active one is uncommented
# and matches the docker-compose default. To switch to a managed/
# cloud database, comment out the local line and uncomment the
# cloud line, replacing the placeholders with your real credentials.

# Option A — Local (docker-compose `db` service, default)
DATABASE_URL="postgresql://postgres:postgres@localhost:51214/homara?schema=public"

# Option B — Managed / cloud database (Supabase, Neon, RDS, etc.)
# DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DBNAME?schema=public"

# Optional: shadow database for Prisma migrations
# SHADOW_DATABASE_URL="postgresql://postgres:postgres@localhost:51214/homara_shadow?schema=public"

# Server port (matches BACKEND_PORT in docker-compose.yml)
PORT=5000

# JWT signing secret
JWT_SECRET="homara_jwt_secret_key_2026_secure"

# ---------------------------------------------------------------
# Optional: override any of the inlined defaults of docker-compose.yml.
# Uncomment and edit only the lines you want to change; the rest
# fall back to the inlined defaults of docker-compose.yml.
# ---------------------------------------------------------------

# PostgreSQL credentials (used by the `db` service in compose)
# POSTGRES_USER=postgres
# POSTGRES_PASSWORD=postgres
# POSTGRES_DB=homara

# Host port mappings
# POSTGRES_PORT=51214      # host port → DB container (5432)
# BACKEND_PORT=5000        # host port → backend container
# PRISMA_STUDIO_PORT=5555  # host port for Prisma Studio (only with `--profile tools`)
