# ============================================
# Homara — Environment Variables
# ============================================

# Database Connection URL (Choose one option below and replace the placeholder variables)

# Option A: Local PostgreSQL Database (e.g., using Docker Compose)
# DATABASE_URL="postgresql://postgres:postgres@localhost:51214/homara?sslmode=disable&connection_limit=10"

# Option B: Remote / Cloud PostgreSQL Database (e.g., Supabase, Neon, Render, AWS RDS)
# Replace placeholders with your actual remote database credentials
DATABASE_URL="postgresql://[USER]:[PASSWORD]@[HOST]:[PORT]/[DATABASE_NAME]"

# Shadow database (Only required if running local database migrations)
# SHADOW_DATABASE_URL="postgresql://postgres:postgres@localhost:51214/homara_shadow?sslmode=disable&connection_limit=10"

# Server port
PORT=5000

# JWT Secrets
JWT_SECRET="homara_jwt_secret_key_2026_secure"
