# ============================================
# Homara — Environment Variables
# ============================================

# Direct PostgreSQL connection (used by Prisma CLI for migrations)
DATABASE_URL="postgres://postgres:postgres@localhost:51214/homara?sslmode=disable&connection_limit=10"

# Shadow database for Prisma Migrate
SHADOW_DATABASE_URL="postgres://postgres:postgres@localhost:51214/homara_shadow?sslmode=disable&connection_limit=10"

# Server port
PORT=5000