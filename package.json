{
  "name": "backend",
  "version": "1.0.0",
  "description": "",
  "main": "dist/infrastructure/entrypoints/api.js",
  "scripts": {
    "dev": "tsx watch src/infrastructure/entrypoints/api.ts",
    "start": "npx prisma db push && npm run seed && tsx src/infrastructure/entrypoints/api.ts",
    "seed": "tsx prisma/seed.ts",
    "build": "npx prisma generate && tsc",
    "test": "vitest run",
    "validate": "tsx validate-prisma.ts",
    "k8s:deploy": "minikube image build -t homara-backend:latest . && kubectl apply -f k8s/",
    "k8s:status": "kubectl get pods,svc -n homara",
    "k8s:grafana": "minikube service homara-grafana -n homara",
    "k8s:backend": "minikube service homara-backend -n homara"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "module",
  "dependencies": {
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "bcryptjs": "^3.0.3",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "jsonwebtoken": "^9.0.3",
    "pg": "^8.21.0",
    "swagger-jsdoc": "^6.3.0",
    "swagger-ui-express": "^5.0.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^25.6.0",
    "@types/pg": "^8.20.0",
    "@types/swagger-jsdoc": "^6.0.4",
    "@types/swagger-ui-express": "^4.1.8",
    "prisma": "^7.8.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.7"
  }
}
